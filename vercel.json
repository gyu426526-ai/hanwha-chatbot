{
  "builds": [
    { "src": "api/chat.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "products.js", "use": "@vercel/static" },
    { "src": "products.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.py" },
    { "src": "/products.js", "dest": "/products.js" },
    { "src": "/products.json", "dest": "/products.json" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
